# =============================================================================
# Highscore Tech — environment template
# =============================================================================
# Copy to `.env.local` and fill in the real values. The five "Required"
# variables must be set for the app to start; the rest fall back to sane
# defaults when missing.

# ── App ──────────────────────────────────────────────────────────────────────
# Required — used in canonical URLs, OG metadata, sitemap, robots.
NEXT_PUBLIC_APP_URL=https://highzcore.tech
# Optional — overrides the display name in <title> templates.
NEXT_PUBLIC_SITE_NAME=Highscore Tech

# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
#   Project URL      → NEXT_PUBLIC_SUPABASE_URL
#   anon/public key  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   service_role key → SUPABASE_SERVICE_ROLE_KEY   (keep secret)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── ALATPay (WEMA Bank payment gateway) ──────────────────────────────────────
# Both are passed to the inline SDK in the browser, so both must be
# NEXT_PUBLIC_. The API key here is ALATPay's public key, not a server secret.
NEXT_PUBLIC_ALATPAY_BUSINESS_ID=
NEXT_PUBLIC_ALATPAY_API_KEY=
# Optional — override only when ALATPay rotates URLs or you point at sandbox.
# NEXT_PUBLIC_ALATPAY_SDK_URL=https://payment-checkout.alatpay.ng/AlatPay.js
# ALATPAY_API_BASE=https://apibox.alatpay.ng

# ── Staff portal session ─────────────────────────────────────────────────────
# HMAC secret for signing the staff-portal cookie and peppering the personal-
# email hash. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, falls back to SUPABASE_SERVICE_ROLE_KEY.
STAFF_SESSION_SECRET=

# ── Cron secret ──────────────────────────────────────────────────────────────
# Shared secret used by every /api/cron/* endpoint. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Your hosting platform's scheduled-function facility must POST to the cron
# endpoints with header `X-Cron-Secret: <CRON_SECRET>`. Common patterns:
#   • Netlify Scheduled Functions
#   • Vercel Cron (vercel.json)
#   • External: cron-job.org, EasyCron, etc.
CRON_SECRET=

# ── Gmail SMTP (transactional email) ─────────────────────────────────────────
# When unset, the send helpers no-op + log to the server console so the rest
# of the app keeps working in local dev.
#
# 1. The mailbox behind GMAIL_USER must have 2-Step Verification enabled.
# 2. Create an app password at https://myaccount.google.com/apppasswords
#    (choose Mail, any device name) and paste the 16-char string below
#    (spaces are stripped automatically).
# 3. For a clean From: address, use a Google Workspace mailbox like
#    hello@highzcore.tech and generate the app password from inside it.
GMAIL_USER=hello@highzcore.tech
GMAIL_APP_PASSWORD=
EMAIL_FROM=Highscore Tech <hello@highzcore.tech>
EMAIL_ADMIN=admin@highzcore.tech
