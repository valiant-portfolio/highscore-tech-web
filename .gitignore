# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
*.log

# netlify
.netlify
.netlify/

# ngrok config
ngrok-config.yml

# env files (can opt-in for committing if needed)
.env.local

# staff / hr private data — never check personal info into the repo
*.xlsx
hr/
/Staffs*Information*

# private assets (CEO signature image + future private files) — must
# stay on the filesystem but never end up in git or served from /public
/_secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
